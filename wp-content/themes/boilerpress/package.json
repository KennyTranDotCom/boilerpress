{
    "name": "boilerpress",
    "version": "1.0.0",
    "description": "",
    "author": "Kenny Tran",
    "license": "MIT",
    "scripts": {
        "production": "webpack --env NODE_ENV=production --env production",
        "production:watch": "webpack --env NODE_ENV=production --env production --watch",
        "development": "webpack --env NODE_ENV=development",
        "development:watch": "webpack --env NODE_ENV=development --watch",
        "eslint": "eslint assets/scripts/**/*.js",
        "eslint:fix": "eslint assets/scripts/**/*.js --fix",
        "stylelint": "stylelint assets/styles/**/**/*.{css,scss}",
        "stylelint:fix": "stylelint assets/styles/**/**/*.{css,scss} --fix",
        "prettier": "prettier **/**/*.php views/**/**/*.twig assets/styles/**/**/*.{css,scss} assets/scripts/**/*.js webpack/**/*.js",
        "prettier:fix": "prettier --write **/**/*.php views/**/**/*.twig assets/styles/**/**/*.{css,scss} assets/scripts/**/*.js webpack/**/*.js",
        "start": "npm run development:watch"
    },
    "devDependencies": {
        "@babel/core": "^7.16.5",
        "@babel/eslint-parser": "^7.16.5",
        "@babel/preset-env": "^7.16.5",
        "@prettier/plugin-php": "^0.17.6",
        "autoprefixer": "^10.4.0",
        "babel-loader": "^8.2.3",
        "browser-sync": "^2.27.7",
        "browser-sync-webpack-plugin": "^2.3.0",
        "clean-webpack-plugin": "^4.0.0",
        "copy-webpack-plugin": "^7.0.0",
        "css-loader": "^5.2.7",
        "eslint": "^7.32.0",
        "eslint-config-prettier": "^8.3.0",
        "eslint-webpack-plugin": "^2.6.0",
        "image-minimizer-webpack-plugin": "^2.2.0",
        "imagemin-gifsicle": "^7.0.0",
        "imagemin-jpegtran": "^7.0.0",
        "imagemin-optipng": "^8.0.0",
        "imagemin-svgo": "^8.0.0",
        "mini-css-extract-plugin": "^1.6.2",
        "node-sass-magic-importer": "^5.3.2",
        "postcss": "^8.4.5",
        "postcss-loader": "^4.3.0",
        "prettier": "^2.5.1",
        "prettier-plugin-twig-melody": "^0.4.6",
        "sass": "^1.45.1",
        "sass-loader": "^10.2.0",
        "stylelint": "^13.13.1",
        "stylelint-scss": "^3.21.0",
        "stylelint-webpack-plugin": "^2.3.1",
        "webpack": "^5.65.0",
        "webpack-cli": "^4.9.1",
        "webpackbar": "^5.0.2"
    }
}
