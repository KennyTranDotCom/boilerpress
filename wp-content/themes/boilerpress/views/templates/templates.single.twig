{% extends 'bases.default.twig' %}

{% block content %}
    <div class="o-container">
        <article class="c-post c-post__type-{{ post.post_type }}"
            id="post-{{ post.ID }}">
            <img src="{{ post.thumbnail.src|resize(1200, 300) }}" />
            <section class="c-post__main">
                <h1 class="c-post__title">
                    {{ post.title }}
                </h1>
                <p class="c-post__author">
                    <span>By</span><a href="{{ post.author.path }}">
                        {{ post.author.name }}
                    </a><span>&bull;</span>
                    <time datetime="{{ post.date|date('Y-m-d H:i:s') }}">
                        {{ post.date }}
                    </time>
                </p>
                <div class="c-post__content">
                    {{ post.content }}
                </div>
            </section>
        </article>
    </div>
{% endblock %}
