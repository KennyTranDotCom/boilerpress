<!DOCTYPE html>
<html class="no-js" {{ site.language_attributes }}>
    <head>
        <meta charset="{{ site.charset }}" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title>
            {{ site.name }}
        </title>
        <meta name="description" content="{{ site.description }}" />

        <!-- Icons -->
        <link rel="apple-touch-icon"
            sizes="180x180"
            href="/favicon/apple-touch-icon.png" />
        <link rel="icon"
            type="image/png"
            sizes="32x32"
            href="/favicon/favicon-32x32.png" />
        <link rel="icon"
            type="image/png"
            sizes="16x16"
            href="/favicon/favicon-16x16.png" />
        <link rel="manifest" href="/favicon/site.webmanifest" />
        <link rel="mask-icon"
            href="/favicon/safari-pinned-tab.svg"
            color="#080808" />
        <meta name="apple-mobile-web-app-title" content="Kenny Tran" />
        <meta name="application-name" content="Kenny Tran" />
        <meta name="msapplication-TileColor" content="#ffffff" />
        <meta name="theme-color" content="#ffffff" />

        <!-- Prevent FOUC -->
        <style>
            .is-dom-loading body { opacity: 0; visibility: hidden; }
            .is-dom-loading * { -webkit-transition: none!important;
            -moz-transition: none!important; -ms-transition: none!important;
            -o-transition: none!important; transition: none!important; }
        </style>
        <script>
            document.documentElement.className = 'js is-dom-loading';
        </script>
        <!-- END Prevent FOUC -->

        {{ function('wp_head') }}
    </head>
</html>
