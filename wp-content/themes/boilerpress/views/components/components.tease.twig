<article class="c-tease c-tease-{{ post.post_type }}" id="tease-{{ post.ID }}">
    {% block content %}
        {% if post.get_thumbnail %}
            <img class="c-tease__image" src="{{ post.thumbnail.src }}" />
        {% endif %}
        <h2 class="c-tease__title">
            <a href="{{ post.link }}">{{ post.title }}</a>
        </h2>
        <p>
            {{ post.preview }}
        </p>
    {% endblock %}
</article>
